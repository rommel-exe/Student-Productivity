{
  "productName": "OneNoteObsidian",
  "version": "0.0.0",
  "identifier": "com.onenote.obsidian.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 768,
        "resizable": true,
        "title": "OneNote-Obsidian Workspace Studio",
        "width": 1200
      }
    ]
  },
  "bundle": {
    "active": true,
    "category": "Office",
    "copyright": "Copyright © 2026",
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "A beautiful cross-linked student study workspace blending OneNote sections with Obsidian bi-directional study graph nodes.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": ""
    },
    "resources": [],
    "shortDescription": "OneNote structures meet Obsidian links study tool",
    "targets": "all",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/rommel-exe/Student-Productivity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFMzUzNDFGRDVFQkI0NDcKUldSSHRPdlZIelExM3A1Uk8vcEFMVGNUNFFjYWxYd1lCKzVkV1djanR6blQ5azBJR0l0MnBqdk0K"
    }
  }
}
