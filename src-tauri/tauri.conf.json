{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist"
  },
  "package": {
    "productName": "OneNoteObsidian",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "Office",
      "copyright": "Copyright © 2026",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.onenote.obsidian.app",
      "longDescription": "A beautiful cross-linked student study workspace blending OneNote sections with Obsidian bi-directional study graph nodes.",
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": ""
      },
      "resources": [],
      "shortDescription": "OneNote structures meet Obsidian links study tool",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": null
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 768,
        "resizable": true,
        "title": "OneNote-Obsidian Workspace Studio",
        "width": 1200
      }
    ]
  }
}
